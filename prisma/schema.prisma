generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Transaction {
  id        Int      @id @default(autoincrement())
  type      String
  amount    Int
  category  String
  note      String?
  createdAt DateTime @default(now())
}